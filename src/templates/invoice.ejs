<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Confirmation - SkillBridge</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background-color: #f5f7ff; color: #1a1a2e; line-height: 1.6; }
        .wrapper { width: 100%; background-color: #f5f7ff; padding: 40px 20px; }
        .container { max-width: 650px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 24px rgba(99,102,241,0.08); border: 1px solid #e8eaf6; }
        .header { background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); padding: 40px; }
        .header h1 { color: #ffffff; font-size: 28px; font-weight: 700; margin-bottom: 4px; }
        .header p { color: rgba(255,255,255,0.75); font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; }
        .content { padding: 40px; }
        .greeting { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
        .message { font-size: 14px; color: #555; margin-bottom: 32px; }
        .info-box { background-color: #f5f7ff; padding: 24px; border-radius: 6px; margin-bottom: 32px; border-left: 4px solid #6366f1; }
        .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px; }
        .info-label { color: #777; font-weight: 500; }
        .info-value { color: #1a1a2e; font-weight: 600; text-align: right; }
        .section-title { font-size: 16px; font-weight: 600; color: #4f46e5; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #e8eaf6; }
        .amount-box { background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #ffffff; padding: 28px; border-radius: 8px; text-align: center; margin-bottom: 32px; }
        .amount-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; opacity: 0.8; }
        .amount-value { font-size: 40px; font-weight: 700; }
        .cta-container { text-align: center; margin-bottom: 8px; }
        .cta-button { display: inline-block; border: 2px solid #6366f1; color: #6366f1 !important; padding: 12px 32px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; }
        .footer { background-color: #f5f7ff; padding: 24px 40px; border-top: 1px solid #e8eaf6; }
        .footer p { font-size: 11px; color: #aaa; margin-bottom: 4px; }
        @media (max-width: 600px) {
            .header { padding: 24px; }
            .content { padding: 24px; }
            .info-row { flex-direction: column; }
            .info-value { text-align: left; margin-top: 2px; }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>SkillBridge</h1>
                <p>Payment Confirmation Receipt</p>
            </div>
            <div class="content">
                <div class="greeting">Dear <%= payeeName %>,</div>
                <p class="message">Your payment has been successfully processed. Thank you for choosing SkillBridge.</p>

                <div class="section-title">Invoice Details</div>
                <div class="info-box">
                    <div class="info-row">
                        <span class="info-label">Invoice ID:</span>
                        <span class="info-value"><%= invoiceId %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Transaction ID:</span>
                        <span class="info-value"><%= transactionId %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Payment Date:</span>
                        <span class="info-value"><%= paymentDate %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status:</span>
                        <span class="info-value" style="color: #22c55e;">✓ Confirmed Paid</span>
                    </div>
                </div>

                <div class="section-title">
                    <% if (type === 'course') { %>Course Enrolled<% } else { %>Session Booked<% } %>
                </div>
                <div style="margin-bottom: 32px;">
                    <p style="font-weight: 700; color: #4f46e5; font-size: 17px;"><%= itemTitle %></p>
                    <p style="color: #666; font-size: 14px; margin-top: 4px;"><%= itemSubtitle %></p>
                </div>

                <div class="amount-box">
                    <div class="amount-label">Total Amount Paid</div>
                    <div class="amount-value"><%= amount.toFixed(2) %> <%= currency.toUpperCase() %></div>
                </div>

                <% if (invoiceUrl) { %>
                <div class="cta-container">
                    <a href="<%= invoiceUrl %>" class="cta-button">Download PDF Invoice</a>
                </div>
                <% } %>
            </div>
            <div class="footer">
                <p>© 2026 SkillBridge. All rights reserved.</p>
                <p>This is an automatically generated receipt. Please do not reply to this email.</p>
                <p>Payment processed securely through Stripe.</p>
            </div>
        </div>
    </div>
</body>
</html>
